{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dictatr",
  "version": "0.1.0",
  "identifier": "de.dss.dictatr",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Dictatr Settings",
        "width": 960,
        "height": 820,
        "visible": false
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "width": 220,
        "height": 60,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": { "csp": null },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": ["icons/icon.ico"]
  }
}
